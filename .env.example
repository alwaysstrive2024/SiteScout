# ─────────────────────────────────────────────────────────────────────────────
# SiteScout (灵嗅) – Environment Configuration
# Copy this file to `.env` and fill in your real keys. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Search Engine (pick one) ──────────────────────────────────────────────────
# Bocha AI  →  https://open.bochaai.com/
BOCHA_API_KEY=sk-your-bocha-key-here

# Tavily    →  https://tavily.com/   (fallback / alternative)
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Active search provider: "bocha" | "tavily" ───────────────────────────────
SEARCH_PROVIDER=bocha

# ── LLM ───────────────────────────────────────────────────────────────────
# DeepSeek    →  https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenAI      →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# model_choice options: deepseek-chat | gpt-4o | gpt-4o-mini

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
